<Project>
  <!-- Generator MSBuild options (see README Configuration). Packed as buildTransitive/ZeroAlloc.props. -->
  <PropertyGroup>
    <ZeroAlloc_DefaultBufferSize Condition="'$(ZeroAlloc_DefaultBufferSize)' == ''">2097152</ZeroAlloc_DefaultBufferSize>
    <ZeroAlloc_RecursiveHeapFallback Condition="'$(ZeroAlloc_RecursiveHeapFallback)' == ''">true</ZeroAlloc_RecursiveHeapFallback>
    <ZeroAlloc_BufferOverflowBehavior Condition="'$(ZeroAlloc_BufferOverflowBehavior)' == ''">Grow</ZeroAlloc_BufferOverflowBehavior>
  </PropertyGroup>
  <ItemGroup>
    <CompilerVisibleProperty Include="ZeroAlloc_DefaultBufferSize" />
    <CompilerVisibleProperty Include="ZeroAlloc_RecursiveHeapFallback" />
    <CompilerVisibleProperty Include="ZeroAlloc_BufferOverflowBehavior" />
  </ItemGroup>
</Project>
